MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/tranzgoo?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development
APP_NAME=TranzGOO

# Required in production for password reset emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM="TranzGOO <no-reply@example.com>"

# Optional. If set, password reset emails include a link with ?token=...
# PASSWORD_RESET_URL=https://your-app.example.com/reset-password

